{
  "builds": [
    {
      "src": "Backend/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "Backend/app.py"
    }
  ],
  "functions": {
    "Backend/app.py": {
      "excludeFiles": "{**/*.graphml,**/dataset/**,cache/**,screenshots/**}"
    }
  }
}