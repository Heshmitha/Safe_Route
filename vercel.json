{
  "builds": [
    {
      "src": "Backend/app.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": "{**/*.graphml,**/dataset/**,cache/**,screenshots/**}"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "Backend/app.py"
    }
  ]
}